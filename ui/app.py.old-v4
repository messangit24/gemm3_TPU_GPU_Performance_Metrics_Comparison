# ==========================================
# Tabs Setup
# ==========================================
tab_dashboard, tab_glossary = st.tabs(["🚀 Live Dashboard", "📖 Metrics Glossary & Math"])

with tab_dashboard:
    col_chat, col_dash = st.columns([1.5, 1.2])

    with col_chat:
        st.markdown("<div class='custom-header'>Accelerator Insights</div>", unsafe_allow_html=True)
        
        chat_container = st.container(height=520)
        with chat_container:
            for message in st.session_state.messages:
                with st.chat_message(message["role"]):
                    st.markdown(message["content"])

        if prompt := st.chat_input("Ask a Question..."):
            
            if file_context and len(st.session_state.messages) == 0:
                full_prompt = f"Context:\n{file_context}\n\nQuestion: {prompt}"
            else:
                full_prompt = prompt

            st.session_state.messages.append({"role": "user", "content": full_prompt})
            
            sanitized = []
            for m in st.session_state.messages:
                if not sanitized:
                    if m["role"] == "user":
                        sanitized.append(m)
                else:
                    if m["role"] != sanitized[-1]["role"]:
                        sanitized.append(m)
                    else:
                        sanitized[-1] = m
                        
            st.session_state.messages = sanitized
            
            with chat_container:
                with st.chat_message("user"):
                    st.markdown(prompt)

                with st.chat_message("assistant"):
                    message_placeholder = st.empty()
                    full_response = ""
                    start_time = time.time()
                    ttft_sec = 0.0
                    first_token_received = False
                    input_tokens = 0
                    output_tokens = 0
                    
                    error_occurred = False
                    
                    try:
                        response_stream = client.chat.completions.create(
                            model=endpoint_config["model_name"],
                            messages=st.session_state.messages,
                            stream=True,
                            stream_options={"include_usage": True} 
                        )
                        
                        for chunk in response_stream:
                            if not first_token_received and len(chunk.choices) > 0 and chunk.choices[0].delta.content:
                                ttft_sec = time.time() - start_time
                                first_token_received = True

                            if len(chunk.choices) > 0 and chunk.choices[0].delta.content:
                                full_response += chunk.choices[0].delta.content
                                message_placeholder.markdown(full_response + "▌")
                            
                            if chunk.usage:
                                input_tokens = chunk.usage.prompt_tokens
                                output_tokens = chunk.usage.completion_tokens
                        
                        message_placeholder.markdown(full_response)
                    except Exception as e:
                        # We print the error but DO NOT use st.stop() anymore!
                        st.error(f"vLLM Generation Error: {e}")
                        error_occurred = True
                        
                    if not error_occurred:
                        total_time_sec = time.time() - start_time
                        decode_time_sec = total_time_sec - ttft_sec

            # Only calculate metrics and save to history if there was no connection error
            if not error_occurred:
                st.session_state.messages.append({"role": "assistant", "content": full_response})

                tokens_sec, tpot_sec, tflops, mfu, mbu = calculate_derived_metrics(
                    output_tokens, total_time_sec, decode_time_sec, endpoint_config["chips"], endpoint_config["parameter_count"],
                    endpoint_config["peak_tflops"], endpoint_config["peak_mem_bw"]
                )
                hw_util = get_latest_hardware_utilization()
                timestamp_dt = datetime.now(timezone.utc)

                metric_record = {
                    "query_timestamp": timestamp_dt,
                    "input_tokens": input_tokens,
                    "output_tokens": output_tokens,
                    "forward_time_sec": round(ttft_sec, 2),
                    "decode_time_sec": round(decode_time_sec, 2),
                    "total_time_sec": round(total_time_sec, 2),
                    "tokens_per_sec": tokens_sec,
                    "tpot_sec": tpot_sec,
                    "tflops": tflops,
                    "mfu_percent": mfu,
                    "hw_utilization": hw_util,
                    "mbu_percent": mbu,
                    "model_name": endpoint_config["model_name"],
                    "parameter_size": endpoint_config["parameter_size"]
                }

                st.session_state.session_metrics.append(metric_record)
                
                success, save_err = save_metrics_to_bigquery(metric_record, endpoint_config["bq_table"], endpoint_config["util_column"])
                if not success:
                    st.toast(f"Note: Could not save to BigQuery. {save_err}", icon="⚠️")
                    
                st.rerun()

    with col_dash:
        st.markdown("<div class='custom-header'>Performance Metrics</div>", unsafe_allow_html=True)
        
        dash_container = st.container(height=520)
        
        with dash_container:
            if st.session_state.session_metrics:
                st.markdown("### Latest Query Speed")
                latest = st.session_state.session_metrics[-1]
                
                t1, t2, t3 = st.columns(3)
                t1.metric("TTFT", f"{latest['forward_time_sec']} s")
                t2.metric("TPOT", f"{latest['tpot_sec']} s")
                t3.metric("Total Time", f"{latest['total_time_sec']} s")
                
                m1, m2, m3 = st.columns(3)
                m1.metric("Tokens/Sec", f"{latest['tokens_per_sec']} t/s")
                m2.metric("MFU", f"{latest['mfu_percent']} %")
                m3.metric("MBU", f"{latest['mbu_percent']} %")
                st.markdown("---")
                
            st.markdown("### Historical Trends")
            time_filter = st.selectbox(
                "Select Timeframe",
                ["Last 5 Minutes", "Last 1 Hour", "Last 24 Hours", "Last 7 Days", "Last 30 Days", "Custom Range"],
                index=0,
                label_visibility="collapsed"
            )
            
            custom_start, custom_end = None, None
            if time_filter == "Custom Range":
                c1, c2 = st.columns(2)
                custom_start = c1.date_input("Start Date", value=datetime.today() - timedelta(days=7))
                custom_end = c2.date_input("End Date", value=datetime.today())

            bq_data, fetch_error = get_filtered_history(time_filter, endpoint_config, custom_start, custom_end)
            
            if fetch_error:
                st.warning(f"Could not load database history: {fetch_error}")
            
            df_bq = pd.DataFrame(bq_data) if bq_data else pd.DataFrame()
            df_local = pd.DataFrame(st.session_state.session_metrics)
            
            if df_bq.empty and df_local.empty:
                st.info("No metric data found for this timeframe.")
            else:
                df = pd.concat([df_bq, df_local], ignore_index=True)
                
                df['query_timestamp'] = pd.to_datetime(df['query_timestamp'], utc=True)
                df['query_timestamp'] = df['query_timestamp'].dt.tz_convert(LOCAL_TZ)
                df['query_timestamp'] = df['query_timestamp'].dt.tz_localize(None)
                
                df = df.drop_duplicates(subset=['query_timestamp'], keep='last')
                df = df.sort_values(by="query_timestamp")
                
                util_col = endpoint_config["util_column"]
                util_label = endpoint_config["util_label"]

                if 'tpot_sec' not in df.columns: df['tpot_sec'] = 0.0
                if 'mbu_percent' not in df.columns: df['mbu_percent'] = 0.0
                if util_col not in df.columns: df[util_col] = 0.0 
                if 'hw_utilization' in df.columns: df[util_col] = df['hw_utilization']

                df['tpot_sec'] = df['tpot_sec'].fillna(0.0)
                df['mbu_percent'] = df['mbu_percent'].fillna(0.0)
                df[util_col] = df[util_col].fillna(0.0)

                df.rename(columns={
                    "forward_time_sec": "TTFT (s)",
                    "tpot_sec": "TPOT (s)",
                    "total_time_sec": "Total (s)",
                    "tokens_per_sec": "Tokens/Sec",
                    "input_tokens": "Input Tokens",
                    "output_tokens": "Output Tokens",
                    "mfu_percent": "MFU (%)",
                    "mbu_percent": "MBU (%)",
                    util_col: util_label,
                    "tflops": "TFLOPs",
                    "model_name": "Model",
                    "parameter_size": "Params"
                }, inplace=True)
                
                color_split = "Params" if "Params" in df.columns else None
                
                fig_timing = plot_custom_chart(df, ["TTFT (s)", "TPOT (s)", "Total (s)"], "Timing & Latency", "line", "Seconds")
                st.plotly_chart(fig_timing, use_container_width=True)

                fig_tps = plot_custom_chart(df, ["Tokens/Sec"], "Throughput", "area", "Tokens / Sec", color_col=color_split)
                st.plotly_chart(fig_tps, use_container_width=True)
                
                fig_tokens = plot_custom_chart(df, ["Input Tokens", "Output Tokens"], "Token Volume", "bar", "Tokens")
                st.plotly_chart(fig_tokens, use_container_width=True)
                
                fig_hw = plot_custom_chart(df, ["MFU (%)", "MBU (%)", util_label], "Hardware Utilization", "line", "Percent (%)")
                st.plotly_chart(fig_hw, use_container_width=True)
                    
                fig_flops = plot_custom_chart(df, ["TFLOPs"], "Compute Performance", "area", "TFLOPs", color_col=color_split)
                st.plotly_chart(fig_flops, use_container_width=True)

                st.subheader("Query Log")
                
                display_df = df[[
                    "query_timestamp", "Model", "Params", "Input Tokens", "Output Tokens", 
                    "TTFT (s)", "TPOT (s)", "Total (s)", 
                    "Tokens/Sec", "TFLOPs", "MFU (%)", "MBU (%)", util_label
                ]].copy()
                
                display_df['query_timestamp'] = display_df['query_timestamp'].dt.strftime('%Y-%m-%d %H:%M:%S')
                display_df.rename(columns={"query_timestamp": "Timestamp (EST)"}, inplace=True)
                display_df = display_df.set_index("Timestamp (EST)")
                
                styled_df = display_df.style.background_gradient(
                    cmap='Blues', subset=["Tokens/Sec", "TFLOPs"]
                ).format({
                    "TTFT (s)": "{:.2f}",
                    "TPOT (s)": "{:.3f}",
                    "Total (s)": "{:.2f}",
                    "Tokens/Sec": "{:.2f}",
                    "TFLOPs": "{:.2f}",
                    "MFU (%)": "{:.2f}",
                    "MBU (%)": "{:.2f}",
                    util_label: "{:.2f}"
                })
                
                st.dataframe(styled_df, use_container_width=True)

with tab_glossary:
    st.title("📖 Inference Metrics Glossary")
    st.markdown("This tab breaks down how each TPU inference metric is calculated under the hood, standard units, and what it indicates about your model's performance.")
    
    st.markdown("---")
    
    st.subheader("⏱️ Timing & Latency Metrics")
    st.markdown("""
    **TTFT (Time to First Token)**
    * **Unit:** Seconds (s)
    * **Description:** The time elapsed from the exact moment the prompt is submitted to the API until the very first token is returned to the user. This encapsulates network latency, API queueing, and the entire compute-heavy "Prefill" phase (the forward pass over the prompt).
    * **Process:** `ttft = time_first_token_received - start_time`
      
    **TPOT (Time Per Output Token)**
    * **Unit:** Seconds / Token (s/token)
    * **Description:** The average time required to generate each individual token *after* the first token has been received. This represents the speed of the autoregressive "Decode" phase.
    * **Process:** """)
    st.latex(r"TPOT = \frac{\text{Total Time} - \text{TTFT}}{\text{Output Tokens}}")

    st.markdown("""
    **Total Time**
    * **Unit:** Seconds (s)
    * **Description:** End-to-end request time from submission to the final token generated.
    * **Process:** `total_time = time_final_token - start_time`
    """)
    
    st.markdown("---")
    
    st.subheader("🚀 Throughput & Compute Metrics")
    st.markdown("""
    **Tokens/Sec (Throughput)**
    * **Unit:** Tokens / Second (t/s)
    * **Description:** The overarching speed of token generation across the entire request.
    * **Process:** """)
    st.latex(r"\text{Tokens/Sec} = \frac{\text{Output Tokens}}{\text{Total Time}}")

    st.markdown("""
    **TFLOPs (Tera Floating-Point Operations Per Second)**
    * **Unit:** TFLOPs
    * **Description:** The theoretical number of floating-point operations executed per second by the TPU mesh to generate the response. We assume 2 FLOPs per parameter per token (1 multiply, 1 accumulate).
    * **Process:** """)
    st.latex(r"\text{TFLOPs} = \frac{2 \times \text{Parameter Count} \times \text{Tokens/Sec}}{10^{12}}")

    st.markdown("---")
    
    st.subheader("⚙️ Hardware Utilization Metrics")
    st.markdown("""
    **MFU (Model FLOPs Utilization)**
    * **Unit:** Percent (%)
    * **Description:** The percentage of the theoretical peak compute capacity actually being used. 
    * **Process:** """)
    st.latex(r"MFU = \left( \frac{\text{Achieved TFLOPs}}{\text{Peak TFLOPs per Chip} \times \text{Number of Chips}} \right) \times 100")

    st.markdown("""
    **MBU (Memory Bandwidth Utilization)**
    * **Unit:** Percent (%)
    * **Description:** The percentage of the theoretical high-bandwidth memory (HBM) transfer speed being utilized during the decode phase. Evaluated assuming 2 bytes per parameter (bfloat16).
    * **Process:** """)
    st.latex(r"MBU = \left( \frac{\text{Parameter Count} \times 2 \text{ bytes} \times \text{Decode Tokens/Sec}}{\text{Peak Mem Bandwidth per Chip} \times \text{Number of Chips}} \right) \times 100")

    st.markdown("""
    **MXU (%) / SM Util (%)**
    * **Unit:** Percent (%)
    * **Description:** Unlike MFU (which is derived mathematically from token outputs), this is a live hardware-level metric pulled directly from Google Cloud Monitoring (`kubernetes.io/container/accelerator/duty_cycle`). On TPUs, it shows the physical active duty cycle of the Matrix Multiply Units. On GPUs, it shows the Streaming Multiprocessor utilization.
    """)
