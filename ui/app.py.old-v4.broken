# ==========================================
# Helper: Endpoint Health Check
# ==========================================
def check_endpoint_health(url: str) -> tuple[bool, str]:
    """
    Attempt a GET /health against the inference endpoint.
    Returns (is_healthy, error_message).
    """
    try:
        health_url = url.replace("/v1", "") + "/health"
        r = httpx.get(health_url, timeout=5.0)
        return r.status_code == 200, ""
    except httpx.ConnectError:
        return False, "Connection refused — pod may still be loading."
    except httpx.TimeoutException:
        return False, "Health check timed out."
    except Exception as e:
        return False, str(e)


# ==========================================
# Helper: Timeframe → BigQuery fetch
# ==========================================
def get_filtered_history(
    time_label: str,
    endpoint_cfg: dict,
    custom_start=None,
    custom_end=None,
) -> tuple[list[dict], str]:
    now_utc = datetime.now(timezone.utc)

    if time_label == "Last 5 Minutes":
        start_time = now_utc - timedelta(minutes=5)
    elif time_label == "Last 1 Hour":
        start_time = now_utc - timedelta(hours=1)
    elif time_label == "Last 24 Hours":
        start_time = now_utc - timedelta(hours=24)
    elif time_label == "Last 7 Days":
        start_time = now_utc - timedelta(days=7)
    elif time_label == "Last 30 Days":
        start_time = now_utc - timedelta(days=30)
    elif time_label == "Custom Range" and custom_start and custom_end:
        start_local = datetime.combine(
            custom_start, datetime.min.time(), tzinfo=LOCAL_TZ
        )
        end_local = datetime.combine(
            custom_end, datetime.max.time(), tzinfo=LOCAL_TZ
        )
        return fetch_bigquery_metrics(
            start_local.astimezone(timezone.utc),
            endpoint_cfg["bq_table"],
            end_local.astimezone(timezone.utc),
        )
    else:
        start_time = now_utc - timedelta(hours=24)

    return fetch_bigquery_metrics(start_time, endpoint_cfg["bq_table"], now_utc)


# ==========================================
# Helper: Plotly Chart Factory
# ==========================================
def plot_custom_chart(
    df: pd.DataFrame,
    y_columns: list[str],
    title: str,
    chart_type: str = "line",
    y_title: str = "Value",
    color_col: str | None = None,
) -> px.Figure:
    """
    Render a Plotly figure using the shared dashboard style.
    Falls back to scatter when only one data point exists.
    """
    # Single data-point guard — line/area charts look broken with 1 point
    if len(df) == 1:
        fig = px.scatter(
            df, x="query_timestamp", y=y_columns, title=title, color=color_col
        )
        fig.update_traces(
            marker=dict(size=12, line=dict(width=2, color="DarkSlateGrey"))
        )
    else:
        if chart_type == "area":
            fig = px.area(
                df,
                x="query_timestamp",
                y=y_columns,
                title=title,
                color=color_col,
            )
        elif chart_type == "bar":
            fig = px.bar(
                df,
                x="query_timestamp",
                y=y_columns,
                title=title,
                barmode="group",
                color=color_col,
            )
        else:
            fig = px.line(
                df,
                x="query_timestamp",
                y=y_columns,
                title=title,
                markers=True,
                color=color_col,
            )

    fig.update_layout(
        plot_bgcolor="rgba(0,0,0,0)",
        paper_bgcolor="rgba(0,0,0,0)",
        legend_title_text="",
        legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1),
        margin=dict(l=0, r=0, t=40, b=0),
        hovermode="x unified",
        xaxis_title="",
        yaxis_title=y_title,
    )
    fig.update_xaxes(
        showgrid=True, gridcolor="rgba(128, 128, 128, 0.2)", zeroline=False
    )
    fig.update_yaxes(
        showgrid=True, gridcolor="rgba(128, 128, 128, 0.2)", zeroline=False
    )
    return fig


# ==========================================
# Helper: Build & de-duplicate metrics DataFrame
# ==========================================
def build_metrics_dataframe(
    bq_data: list[dict],
    session_data: list[dict],
    util_col: str,
    util_label: str,
) -> pd.DataFrame:
    """
    Merge BigQuery history with in-session metrics, de-duplicate,
    rename columns for display, and return a sorted DataFrame.
    """
    df_bq = pd.DataFrame(bq_data) if bq_data else pd.DataFrame()
    df_local = pd.DataFrame(session_data) if session_data else pd.DataFrame()

    if df_bq.empty and df_local.empty:
        return pd.DataFrame()

    df = pd.concat([df_bq, df_local], ignore_index=True)

    # Normalise timestamps → local tz → tz-naive for Plotly
    df["query_timestamp"] = pd.to_datetime(df["query_timestamp"], utc=True)
    df["query_timestamp"] = df["query_timestamp"].dt.tz_convert(LOCAL_TZ)
    df["query_timestamp"] = df["query_timestamp"].dt.tz_localize(None)

    df = df.drop_duplicates(subset=["query_timestamp"], keep="last")
    df = df.sort_values("query_timestamp").reset_index(drop=True)

    # Ensure all expected columns exist before renaming
    for col, default in [
        ("tpot_sec", 0.0),
        ("mbu_percent", 0.0),
        (util_col, 0.0),
    ]:
        if col not in df.columns:
            df[col] = default

    # hw_utilization (live metric) overrides the BQ column if both present
    if "hw_utilization" in df.columns:
        df[util_col] = df["hw_utilization"].combine_first(df[util_col])

    df["tpot_sec"] = df["tpot_sec"].fillna(0.0)
    df["mbu_percent"] = df["mbu_percent"].fillna(0.0)
    df[util_col] = df[util_col].fillna(0.0)

    df.rename(
        columns={
            "forward_time_sec": "TTFT (s)",
            "tpot_sec": "TPOT (s)",
            "total_time_sec": "Total (s)",
            "tokens_per_sec": "Tokens/Sec",
            "input_tokens": "Input Tokens",
            "output_tokens": "Output Tokens",
            "mfu_percent": "MFU (%)",
            "mbu_percent": "MBU (%)",
            util_col: util_label,
            "tflops": "TFLOPs",
            "model_name": "Model",
            "parameter_size": "Params",
        },
        inplace=True,
    )

    return df


